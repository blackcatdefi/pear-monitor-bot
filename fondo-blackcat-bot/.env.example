# Telegram Bot (python-telegram-bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telethon userbot (para leer canales)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELETHON_SESSION=

# APIs
ANTHROPIC_API_KEY=
COINGLASS_API_KEY=

# RPC / chains
HYPERLIQUID_API=https://api.hyperliquid.xyz
HYPEREVM_RPC=https://rpc.hyperliquid.xyz/evm
HYPERLEND_POOL_ADDRESS=0x00A89d7a5A02160f20150EbEA7a2b5E4879A1A8b

# Bot config
POLL_INTERVAL_MIN=5
ENABLE_ALERTS=true

# ─── R-PMCORE (2026-06-01) — post-migración HyperLend → Portfolio Margin ───
# Wallet primaria que tiene el HYPE spot (colateral cross de Portfolio Margin).
PM_PRIMARY_WALLET=0xc7ae23316b47f7e75f455f53ad37873a18351505
# LTV de HYPE en PM (capacidad de borrow = LTV × colateral).
PM_HYPE_LTV=0.50
# Umbrales del margin ratio (deuda/capacidad): WARN / STRESS / LIQUIDACIÓN.
PM_WARN_RATIO=0.40
PM_STRESS_RATIO=0.70
PM_LIQ_RATIO=0.95
# Activos spot PM-elegibles como colateral (CSV). Default: HYPE.
PM_COLLATERAL_ASSETS=HYPE
# Watchdog PM (edge-triggered, rompe R-SILENT solo en WARN/naked-long).
PM_MONITOR_ENABLED=true
PM_MONITOR_INTERVAL_MIN=15
# Flywheel HyperLend DEPRECADO (cerrado, migrado a PM). true = no contar
# colateral/deuda HL stale en TOTAL EQUITY. Rollback: false.
FLYWHEEL_DEPRECATED=true
# Auto-descubrir TODOS los vaults donde la wallet del fondo tiene equity.
VAULT_AUTODISCOVER=true
VAULT_DUST_USD=1.0
